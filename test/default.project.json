{
	"name": "charm-devtools",
	"servePort": 32423,
	"globIgnorePaths": ["**/package.json", "**/tsconfig.json", "**/*.ts"],
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"rbxts_include": {
				"$path": "include",
				"node_modules": {
					"$className": "Folder",
					"@rbxts": {
						"$path": "node_modules/@rbxts",
						"charm-devtools": {
							"$path": "../charm-devtools/out"
						}
					}
				}
			}
		},
		"ServerScriptService": {
			"$className": "ServerScriptService",
			"server": {
				"$path": "out/test.server.luau"
			}
		},
		"StarterPlayer": {
			"$className": "StarterPlayer",
			"StarterPlayerScripts": {
				"$className": "StarterPlayerScripts",
				"client": {
					"$path": "out/test.client.luau"
				}
			}
		}
	}
}
