{
	"name": "charm-devtools",
	"version": "1.0.0",
	"description": "",
	"scripts": {
		"dev": "concurrently \"pnpm watch\" \"pnpm watch:plugin\" \"pnpm watch:test\" \"pnpm serve:test\"",
		"build": "rbxtsc",
		"build:plugin": "rojo build -o %LOCALAPPDATA%/Roblox/Plugins/CharmDevTools.rbxm",
		"serve": "rojo serve default.project.json",
		"serve:test": "rojo serve test/default.project.json",
		"watch": "rbxtsc -w",
		"watch:test": "rbxtsc -w -p test",
		"watch:plugin": "pnpm build:plugin --watch"
	},
	"author": "Speed",
	"license": "MIT",
	"devDependencies": {
		"@rbxts/compiler-types": "3.0.0-types.0",
		"@rbxts/object-utils": "^1.0.4",
		"@rbxts/types": "^1.0.892",
		"roblox-ts": "^3.0.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@rbxts/charm": "0.11.0-rc.2",
		"@rbxts/inspect": "^1.0.1",
		"@rbxts/react": "^17.2.3",
		"@rbxts/react-charm": "0.4.0-rc.2",
		"@rbxts/react-roblox": "^17.2.3",
		"@rbxts/services": "^1.6.0",
		"@rbxts/t": "^3.2.1",
		"@rbxts/ultimate-list": "0.2.3-ts.2",
		"concurrently": "^9.2.1"
	}
}
