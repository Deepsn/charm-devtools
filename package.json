		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@rbxts/react": "^17.2.3",
		"@rbxts/react-charm": "^0.3.0",
		"@rbxts/react-roblox": "^17.2.3",
		"@rbxts/services": "^1.6.0",
		"@rbxts/t": "^3.2.1",
		"@rbxts/ultimate-list": "0.2.3-ts.2"
