{
	"name": "roblox-ts-plugin",
	"globIgnorePaths": ["**/package.json", "**/tsconfig.json", "**/*.ts"],
	"tree": {
		"$path": "out",
		"include": {
			"$path": "include",
			"node_modules": {
				"$className": "Folder",
				"@rbxts": {
					"$path": "node_modules/@rbxts",
					"charm-devtools": {
						"$path": "../charm-devtools/out"
					}
				}
			}
		}
	}
}
